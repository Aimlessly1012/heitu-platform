{
  "name": "heitu",
  "version": "1.0.9",
  "description": "React utility library — hooks, canvas engine & form renderer",
  "keywords": [
    "react",
    "hooks",
    "canvas",
    "form-render",
    "antd",
    "json-schema",
    "react-hooks",
    "canvas-engine"
  ],
  "homepage": "https://github.com/Aimlessly1012/heitu-platform/tree/main/packages/heitu#readme",
  "bugs": {
    "url": "https://github.com/Aimlessly1012/heitu-platform/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Aimlessly1012/heitu-platform.git",
    "directory": "packages/heitu"
  },
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/esm/hooks/index.js",
      "require": "./dist/hooks/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/esm/canvas/index.js",
      "require": "./dist/canvas/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/esm/components/index.js",
      "require": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "dumi dev",
    "build": "father build",
    "build:watch": "father dev",
    "docs:build": "dumi build",
    "docs:preview": "dumi preview",
    "deploy": "gh-pages -d dist",
    "prepare": "dumi setup",
    "doctor": "father doctor",
    "lint": "npm run lint:es && npm run lint:css && npm run tsc",
    "lint:css": "stylelint \"{src,test}/**/*.{css,less}\"",
    "lint:es": "eslint \"{src,test}/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "father doctor && npm run build && npm run test"
  },
  "authors": [
    "peco"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.{css,less}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "antd": ">=5.0.0",
    "axios": ">=1.0.0",
    "js-cookie": ">=3.0.0",
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0",
    "urijs": ">=1.19.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    },
    "js-cookie": {
      "optional": true
    },
    "urijs": {
      "optional": true
    },
    "antd": {
      "optional": true
    }
  },
  "dependencies": {
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@testing-library/react": "^16.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/urijs": "^1.19.25",
    "@umijs/lint": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "antd": "^6.3.5",
    "axios": "^1.7.7",
    "dumi": "^2.3.0",
    "eslint": "^8.23.0",
    "father": "^4.1.0",
    "gh-pages": "^6.1.1",
    "husky": "^8.0.1",
    "js-cookie": "^3.0.5",
    "jsdom": "^25.0.0",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "prettier-plugin-organize-imports": "^3.0.0",
    "prettier-plugin-packagejson": "^2.2.18",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "stylelint": "^14.9.1",
    "typescript": "^5.0.0",
    "urijs": "^1.19.11",
    "vitest": "^2.1.0"
  }
}
